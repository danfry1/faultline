{
  "name": "errorsys-vscode",
  "displayName": "Error System",
  "description": "Type-safe error handling diagnostics for TypeScript — surfaces missing error coverage, shows throwable errors on hover, and provides quick fixes.",
  "version": "0.1.0",
  "publisher": "errorsys",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Linters", "Programming Languages"],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Error System",
      "properties": {
        "errorsys.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable error system diagnostics"
        },
        "errorsys.analyzeOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run analysis when files are saved"
        }
      }
    },
    "commands": [
      {
        "command": "errorsys.analyze",
        "title": "Error System: Analyze Project"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -p . --watch"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "typescript": "^5.3.0"
  }
}
