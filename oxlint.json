{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxlint-config-inspector/main/oxlint_config_schema.json",
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "eqeqeq": "error"
  },
  "ignorePatterns": [
    "dist",
    "out",
    "node_modules",
    "*.d.ts"
  ]
}
