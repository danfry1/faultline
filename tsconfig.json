{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "types": ["bun"]
  },
  "references": [
    { "path": "packages/faultline" },
    { "path": "packages/faultline-cli" },
    { "path": "packages/eslint-plugin-faultline" },
    { "path": "packages/faultline-vscode" }
  ],
  "include": []
}
