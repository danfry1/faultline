{
  "name": "faultline",
  "version": "0.1.0",
  "description": "The complete type-safe error system for TypeScript.",
  "author": "Daniel Fry",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./test": {
      "import": {
        "types": "./dist/test.d.ts",
        "default": "./dist/test.js"
      },
      "require": {
        "types": "./dist/test.d.cts",
        "default": "./dist/test.cjs"
      }
    }
  },
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "scripts": {
    "build": "tsdown src/index.ts src/test.ts --format esm,cjs --dts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build"
  },
  "keywords": [
    "typescript", "errors", "error-handling", "result", "typed-errors",
    "type-safe", "error-system", "faultline"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/danfry1/faultline.git",
    "directory": "packages/faultline"
  },
  "homepage": "https://danfry1.github.io/faultline",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "tsdown": "^0.9.0",
    "typescript": "^5.9.3"
  }
}
